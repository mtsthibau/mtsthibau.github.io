---
import { ArrowRight, BookOpen, Cpu, Radio, Sparkles } from 'lucide-astro';
import profileImage from '../../assets/images/workshops/profile.png';

interface Props {}
---

<div class="relative min-h-screen overflow-hidden bg-[#03060a] text-white" data-hero-root>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(14,165,233,0.2),transparent_32%),radial-gradient(circle_at_bottom_right,rgba(16,185,129,0.12),transparent_24%)]"></div>
  <div class="absolute inset-0 opacity-70" style="background-image: linear-gradient(to right, rgba(255,255,255,0.06) 1px, transparent 1px), linear-gradient(to bottom, rgba(255,255,255,0.06) 1px, transparent 1px); background-size: 42px 42px;"></div>
  <div class="absolute inset-0 opacity-40" style="background-image: linear-gradient(to bottom, transparent 0%, rgba(3,6,10,0.55) 100%);"></div>
  <div class="absolute -left-16 top-16 h-64 w-64 rounded-full bg-primary-500/20 blur-3xl"></div>
  <div class="absolute bottom-0 right-0 h-72 w-72 rounded-full bg-emerald-400/10 blur-3xl"></div>

  <div class="matrix-layer absolute inset-0 overflow-hidden opacity-40"></div>

  <div class="relative z-10 flex min-h-screen flex-col justify-between container-max container-px py-24 sm:py-32">
    <div class="grid items-center gap-12 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="max-w-3xl" data-gsap-hero>
        <p class="mb-4 flex items-center gap-2 text-label uppercase tracking-[0.3em] text-primary-300">
          <Sparkles size={28} />
          Frontend engineer
        </p>
        <h1 class="text-4xl font-semibold leading-[0.95] tracking-tight text-white sm:text-5xl lg:text-7xl">
          I make digital experiences that feel as alive as the ideas behind them.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-neutral-300 sm:text-xl">
          With 15+ years of experience, I design and build websites that blend storytelling, clarity, and resilient engineering for education, humanitarian, and communication-focused products.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <span class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-neutral-200">15+ years experience</span>
          <span class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-neutral-200">HF radio & resilient systems</span>
          <span class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-neutral-200">300k+ students reached</span>
        </div>

        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <a href="#story" class="inline-flex items-center justify-center gap-2 rounded-full bg-primary-600 px-8 py-3 font-medium text-white transition hover:bg-primary-700">
            Enter the experience
            <ArrowRight size={20} />
          </a>
          <a href="/journey" class="inline-flex items-center justify-center gap-2 rounded-full border border-white/15 bg-white/10 px-8 py-3 font-medium text-white transition hover:bg-white/20">
            Explore my journey
            <BookOpen size={20} />
          </a>
        </div>
      </div>

      <div class="relative" data-gsap-hero>
        <div class="absolute inset-0 rounded-[2rem] border border-white/10 bg-white/10 blur-3xl"></div>
        <div class="relative rounded-[2rem] border border-white/15 bg-neutral-900/70 p-6 shadow-[0_30px_80px_rgba(0,0,0,0.35)] backdrop-blur">
          <div class="overflow-hidden rounded-[1.5rem] border border-white/10">
            <img src={profileImage.src} alt="Matheus Thibau" class="h-[420px] w-full object-cover" />
          </div>
          <div class="mt-6 rounded-[1.25rem] border border-white/10 bg-white/5 p-5">
            <p class="flex items-center gap-2 text-sm uppercase tracking-[0.3em] text-primary-300"><Cpu size={20} /> Now building</p>
            <p class="mt-2 text-base leading-relaxed text-neutral-300">
              Web experiences for communities, education, and systems that must work beyond the ideal conditions.
            </p>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-12 grid grid-cols-1 gap-4 sm:grid-cols-3" data-gsap-hero>
      <div class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5 backdrop-blur-sm">
        <p class="flex items-center gap-2 text-3xl font-semibold text-white"><Cpu size={24} />15+</p>
        <p class="mt-1 text-sm text-neutral-400">years shaping products, teams, and interfaces</p>
      </div>
      <div class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5 backdrop-blur-sm">
        <p class="flex items-center gap-2 text-3xl font-semibold text-white"><Radio size={24} />HERMES</p>
        <p class="mt-1 text-sm text-neutral-400">communication software for underserved regions</p>
      </div>
      <div class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5 backdrop-blur-sm">
        <p class="text-3xl font-semibold text-white">5k+</p>
        <p class="mt-1 text-sm text-neutral-400">users supported through operational platforms</p>
      </div>
    </div>

    <div class="mt-10 flex justify-center" data-gsap-hero>
      <a href="#story" class="flex flex-col items-center gap-2 text-sm uppercase tracking-[0.3em] text-neutral-400 transition hover:text-white">
        <span>Scroll</span>
        <span class="text-xl">↓</span>
      </a>
    </div>
  </div>
</div>

<style>
  .matrix-layer {
    background-image:
      linear-gradient(rgba(14, 165, 233, 0.12) 1px, transparent 1px),
      linear-gradient(90deg, rgba(14, 165, 233, 0.12) 1px, transparent 1px);
    background-size: 22px 22px;
    mask-image: linear-gradient(to bottom, black 10%, transparent 90%);
    -webkit-mask-image: linear-gradient(to bottom, black 10%, transparent 90%);
    animation: drift 18s linear infinite;
  }

  .matrix-layer::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      to bottom,
      rgba(16, 185, 129, 0.08) 0px,
      rgba(16, 185, 129, 0.08) 2px,
      transparent 2px,
      transparent 16px
    );
    mix-blend-mode: screen;
    opacity: 0.8;
  }

  @keyframes drift {
    from {
      transform: translateY(-4%);
    }
    to {
      transform: translateY(4%);
    }
  }
</style>
