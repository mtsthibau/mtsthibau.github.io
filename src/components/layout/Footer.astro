---
interface Props {}
---

<footer class="">
  <div class="container-max container-px py-12 sm:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-neutral-300 mb-4">
          About
        </h3>
        <p class="text-sm text-neutral-400 leading-relaxed">
          Engineering communication across cultures. Building technologies for communities around the world.
        </p>
      </div>
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-neutral-300 mb-4">
          Navigation
        </h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/journey" class="text-neutral-400 hover:text-primary-300">Journey</a></li>
          <li><a href="/projects" class="text-neutral-400 hover:text-primary-300">Projects</a></li>
          <li><a href="/communities" class="text-neutral-400 hover:text-primary-300">Communities</a></li>
          <li><a href="/journal" class="text-neutral-400 hover:text-primary-300">Journal</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-neutral-300 mb-4">
          Connect
        </h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="text-neutral-400 hover:text-primary-300">
              GitHub
            </a>
          </li>
          <li>
            <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="text-neutral-400 hover:text-primary-300">
              LinkedIn
            </a>
          </li>
          <li>
            <a href="mailto:contact@example.com" class="text-neutral-400 hover:text-primary-300">
              Email
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 pt-8 flex items-center justify-between">
      <p class="text-xs text-neutral-500">
        © 2024 Matheus Thibau. All rights reserved.
      </p>
      <p class="text-xs text-neutral-500">
        Built with Astro & Tailwind CSS
      </p>
    </div>
  </div>
</footer>
