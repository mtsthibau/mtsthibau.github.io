---
interface Props {}
---

<nav class="sticky top-0 z-50 bg-neutral-50 border-b border-neutral-200">
  <div class="container-max container-px h-16 flex-between">
    <div class="flex items-center gap-8">
      <a href="/" class="text-xl font-bold text-neutral-900 hover:text-primary-600">
        Matheus
      </a>
      <div class="hidden md:flex gap-8">
        <a
          href="/"
          class="text-sm font-medium text-neutral-700 hover:text-primary-600 transition-colors"
        >
          Home
        </a>
        <a
          href="/journey"
          class="text-sm font-medium text-neutral-700 hover:text-primary-600 transition-colors"
        >
          Journey
        </a>
        <a
          href="/projects"
          class="text-sm font-medium text-neutral-700 hover:text-primary-600 transition-colors"
        >
          Projects
        </a>
        <a
          href="/communities"
          class="text-sm font-medium text-neutral-700 hover:text-primary-600 transition-colors"
        >
          Communities
        </a>
        <a
          href="/journal"
          class="text-sm font-medium text-neutral-700 hover:text-primary-600 transition-colors"
        >
          Journal
        </a>
      </div>
    </div>
    <button
      aria-label="Toggle mobile menu"
      class="md:hidden p-2 text-neutral-700 hover:text-primary-600 transition-colors"
    >
      <svg
        class="w-6 h-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"
        />
      </svg>
    </button>
  </div>
</nav>

<style>
  nav {
    box-shadow: 0 1px 0 0 rgba(0, 0, 0, 0.05);
  }
</style>
