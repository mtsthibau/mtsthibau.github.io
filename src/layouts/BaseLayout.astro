---
import Footer from '../components/layout/Footer.astro';
import '../styles/globals.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'Matheus Thibau - Experienced Frontend Engineer',
  description = 'Experienced Frontend engineer crafting resilient digital experiences, design systems, and communication platforms.',
  image = '/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f9f9f9" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://rsms.me" />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />

    <!-- Fonts -->
    <link rel="preload" as="style" href="https://rsms.me/inter/inter.css" />
    <link
      rel="preload"
      as="style"
      href="https://cdn.jsdelivr.net/npm/@fontsource/jetbrains-mono@5.0.0/variable/index.min.css"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
  </head>
  <body class="site-shell">
    <main class="relative min-h-screen">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
    overflow-x: hidden;
  }

  body {
    position: relative;
    min-height: 100vh;
    background-color: #03060a;
    color: #f5f5f5;
  }

  .site-shell {
    background-image:
      radial-gradient(circle at top left, rgba(14, 165, 233, 0.16), transparent 32%),
      radial-gradient(circle at bottom right, rgba(16, 185, 129, 0.12), transparent 24%),
      linear-gradient(to right, rgba(255, 255, 255, 0.05) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
    background-size: auto, auto, 42px 42px, 42px 42px;
    background-attachment: fixed;
  }

  .site-shell::before {
    content: "";
    position: fixed;
    inset: 0;
    background: linear-gradient(to bottom, transparent 0%, rgba(3, 6, 10, 0.68) 100%);
    pointer-events: none;
    z-index: 0;
  }

  main,
  footer {
    position: relative;
    z-index: 1;
  }
</style>
