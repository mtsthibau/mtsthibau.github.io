---
import Footer from '../components/layout/Footer.astro';
import '../styles/globals.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'Matheus Thibau - Experienced Frontend Engineer',
  description = 'Experienced Frontend engineer crafting resilient digital experiences, design systems, and communication platforms.',
  image = '/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f9f9f9" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://rsms.me" />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />

    <!-- Fonts -->
    <link rel="preload" as="style" href="https://rsms.me/inter/inter.css" />
    <link
      rel="preload"
      as="style"
      href="https://cdn.jsdelivr.net/npm/@fontsource/jetbrains-mono@5.0.0/variable/index.min.css"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
  </head>
  <body>
    <main class="min-h-screen">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
    overflow-x: hidden;
  }

  body {
    position: relative;
  }
</style>
